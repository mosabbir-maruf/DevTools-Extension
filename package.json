{
  "name": "devtools-extension",
  "version": "2.0.0",
  "description": "All-in-one developer toolkit: capture screenshots, detect fonts, and pick colors from any webpage. 100% local, zero tracking.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "jspdf": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "wouter": "^3.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "postcss": "^8.4.38",
    "typescript-eslint": "^8.62.1",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.2.2",
    "vite": "^8.1.3"
  }
}
